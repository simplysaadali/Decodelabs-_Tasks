// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The Blueprint: User Schema (matches the training deck)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique // Unique Contact - prevents duplicates
  age       Int // Numeric range, validated by CHECK-like logic
  isActive  Boolean  @default(true) // State flag, defaults to TRUE
  createdAt DateTime @default(now()) // Audit trail, stored in UTC

  @@map("users")
}
