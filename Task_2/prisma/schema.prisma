generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The Blueprint: User Schema (matches the training deck)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique              // Unique Contact - prevents duplicates
  age       Int
  isActive  Boolean  @default(true)        
  createdAt DateTime @default(now())

  @@map("users")
}